# Copy this file to ".env" and fill in your own values.
# ".env" is git-ignored, so your keys stay out of the repo.

# --- API keys (required) ---
ASSEMBLYAI_API_KEY=your_assemblyai_key_here
PICOVOICE_ACCESS_KEY=your_picovoice_key_here

# --- Voiceflow (optional; leave blank to disable "start" voiceflow mode) ---
VOICEFLOW_API_KEY=your_voiceflow_key_here
# VOICEFLOW_USER_ID=raspi
# VOICEFLOW_VERSION_ID=production

# --- Model / asset paths ---
MODEL_KITCHEN=./models/my_model.pt
MODEL_SPEC=./models/my_model_spec.pt
KEYWORD_PATH=./models/hey-pico.ppn

# --- Optional tuning (defaults shown) ---
# API_HOST=0.0.0.0
# API_PORT=5000
# TRANSLATE_TARGET=ms
# PV_DEVICE_INDEX=
# LAST_SEEN_JSON_PATH=last_spec_seen.json
# PRESENCE_JSON_PATH=presence.json
# SPEC_EVERY_N=3
# PRESENCE_PUSH_INTERVAL=15
# SPEC_THRESHOLD=0.60
